@startuml Legal Assist - Backend Architecture (Compact)

!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Inter
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 10
skinparam packageStyle rectangle
skinparam linetype polyline
skinparam nodesep 60
skinparam ranksep 50

title **Legal Assist** — Backend Architecture\n

' ═══════════ ACTORS ═══════════
actor "User\n(React SPA)" as User #E0F2FE

' ═══════════ API LAYER ═══════════
rectangle "**API Layer** (FastAPI)" as API #DBEAFE {
    card "POST /auth/register\nPOST /auth/login" as Auth
    card "POST /upload\nGET  /htoc-status" as Docs
    card "POST /analyze\nGET  /analyze/report" as Analysis
    card "POST /chat/stream\nPOST /chat" as Chat
    card "GET  /history" as History
}

' ═══════════ SERVICE LAYER ═══════════
rectangle "**Services**" as SVC #E8F5E9 {
    card "**AuthService**\nJWT + bcrypt" as AuthSvc
    card "**DocumentParser**\nPyMuPDF · DOCX\nGemini Vision OCR" as Parser
    card "**PIIAnonymizer**\nPresidio patterns\n16 regex recognizers" as PII
    card "**SessionService**\nCRUD · TTL: 2h" as Session
    card "**HistoryService**\nPer-user analysis" as HistSvc
    card "**HTOCBuilder**\nHierarchical TOC\nvia Gemini" as HTOC
    card "**BM25Search**\nBM25Okapi\n+ HTOC boost" as BM25
    card "**TreeSearch**\nLLM navigates\nHTOC tree" as Tree
    card "**GeminiClient**\nAnalysis · Chat\nVision OCR" as Gemini
    card "**ReportGenerator**\nJinja2 → WeasyPrint\n→ PDF" as Report
}

' ═══════════ EXTERNAL ═══════════
database "MongoDB Atlas\n(sessions · users\n· analysis_history)" as Mongo #FEE2E2
cloud "Gemini API\n(3 keys: Analysis,\nChat/HTOC, Vision)" as GeminiAPI #FEF3C7

' ═══════════ CONNECTIONS ═══════════
User --> API : HTTPS + JWT

Auth --> AuthSvc
Docs --> Parser
Docs --> PII
Docs --> Session
Docs --> HTOC : background
Docs --> BM25 : background

Analysis --> Gemini
Analysis --> Tree
Analysis --> PII
Analysis --> Session
Analysis --> Report
Analysis --> HistSvc : auto-save

History --> HistSvc

Chat --> BM25 : "1. keyword search"
Chat --> Tree : "2. LLM fallback"
Chat --> Gemini : "3. generate"
Chat --> PII
Chat --> Session

' Service → External
AuthSvc --> Mongo
Session --> Mongo
HistSvc --> Mongo
Gemini --> GeminiAPI
HTOC --> GeminiAPI
Tree --> GeminiAPI
Parser --> GeminiAPI : Vision OCR\n(scanned docs)

' ═══════════ NOTES ═══════════
note bottom of BM25
  **Hybrid RAG Flow:**
  BM25 keyword (<5ms)
  → low confidence?
  → LLM tree search
  → Gemini answer + SSE
end note

note bottom of PII
  **Privacy-first pipeline**
  All regex, no ML models.
  Aadhaar, PAN, GSTIN,
  email, phone + 10 more.
  ~0MB RAM overhead.
end note

@enduml
