@startuml Legal Assist - Architecture

!theme plain
skinparam backgroundColor #FEFEFE
skinparam defaultFontName Inter
skinparam defaultFontSize 11
skinparam shadowing false
skinparam roundCorner 8
skinparam nodesep 30
skinparam ranksep 30
skinparam padding 4

title **Legal Assist** — System Architecture\n

' ═══════════ TOP ROW: CLIENT ═══════════
actor "User" as U #E0F2FE

rectangle "**React 19 Frontend**" as FE #DBEAFE {
    card "Upload\nDrag & Drop" as Upload
    card "Image\nCapture" as Capture
    card "Dashboard\nChat | Reports" as Dash
}

' ═══════════ MIDDLE: BACKEND ═══════════
rectangle "**FastAPI Backend**" as BE #E8F5E9 {

    card "JWT Auth\nbcrypt | Rate Limit" as Auth

    rectangle "OCR Engine" as OCR #F5F5F5 {
        card "PyMuPDF\n//digital//" as PyMu
        card "Gemini Vision\n//fast mode//" as GVision #FFF8E1
        card "EasyOCR\n//secure mode//\n13+ Indian langs" as EasyOCR #C8E6C9
    }

    card "**PII Anonymizer**\nPresidio · 16 patterns\nSingle-pass O(n)" as PII #FFEBEE

    rectangle "Retrieval + AI" as RAG #FFFDE7 {
        card "HTOC\nTree" as HTOC
        card "BM25\nIndex" as BM25
        card "Analysis\nClauses · Risks" as Ana
        card "Chat\nSSE Stream" as Chat
    }
}

' ═══════════ BOTTOM: EXTERNAL ═══════════
database "**MongoDB**\nSessions (TTL 2h)\nUsers · History" as DB #FEE2E2
cloud "**Gemini 2.5 Flash**\n3 API keys" as Gemini #FEF3C7

' ═══════════ CLEAN CONNECTIONS ═══════════

U --> FE

Upload --> Auth
Capture --> Auth
Dash --> Auth

Auth --> OCR : route by\ndoc type
Auth --> RAG

OCR --> PII : extracted text
PII --> RAG : anonymized text

' OCR to Gemini
GVision --> Gemini : page images

' RAG to externals
HTOC --> Gemini
Ana --> Gemini
Chat --> Gemini
Chat --> BM25

RAG --> DB : cache
Auth --> DB : sessions

' ═══════════ LEGEND ═══════════
legend bottom
  | Mode | OCR Engine | API Calls | Privacy |
  | **Digital** | PyMuPDF | None (local) | Text never leaves server |
  | **Scanned Fast** | Gemini Vision | Yes (batched 5/req) | Images sent to Gemini |
  | **Scanned Secure** | EasyOCR (local) | None | Nothing leaves server |
end legend

@enduml
