@startuml Legal Assist

skinparam backgroundColor #FEFEFE
skinparam defaultFontName Inter
skinparam defaultFontSize 10
skinparam shadowing false
skinparam roundCorner 6
skinparam padding 2
skinparam packageBorderColor #CBD5E1
skinparam rectangleBorderColor #94A3B8
skinparam rectangleBackgroundColor #FFFFFF
skinparam arrowColor #475569
skinparam nodesep 20
skinparam ranksep 25
skinparam packagePadding 10

title **Legal Assist** — System Architecture

' ═══════════ FRONTEND ═══════════

package "Frontend  «React 19 · Vite · Tailwind · shadcn»" as FE #EFF6FF {
    rectangle "Landing | Auth | Upload | Chat+Analysis | History" as Pages
    rectangle "SessionContext «state»" as SC
    Pages -[hidden]- SC
}

' ═══════════ API ═══════════

package "API  «FastAPI · /api/v1»" as API #DBEAFE {
    rectangle "/auth" as AuthR
    rectangle "/upload\n/htoc-status" as DocR
    rectangle "/analyze\n/report" as AnaR
    rectangle "/chat/stream\n«SSE»" as ChatR
    rectangle "/history" as HistR
}

' ═══════════ SERVICES ═══════════

package "Services" as SVC #DCFCE7 {
    together {
        rectangle "**Auth**\nJWT · bcrypt" as AuthS
        rectangle "**Session**\nMongoDB · TTL 2h\nchat cache" as SS
        rectangle "**History**\npersist & restore\nanalysis records" as HS
    }
    together {
        rectangle "**DocumentParser**\nPyMuPDF (digital)\nEasyOCR (scanned)\n13 Indian langs" as DocP
        rectangle "**PIIAnonymizer**\nPresidio · spaCy\n12 Indian recognizers\nreversible mapping" as PII
    }
    together {
        rectangle "**GeminiClient**\ngemini-2.5-flash\nanalysis · chat · JSON\ndual keys · retry" as GC
        rectangle "**HTOCBuilder**\nhierarchical TOC\nLLM-generated" as HTOC
    }
    together {
        rectangle "**TreeSearch**\nvectorless RAG\nLLM over HTOC" as TS
        rectangle "**BM25Search**\nkeyword fallback\nOkapi BM25" as BM25
        rectangle "**ReportGen**\nWeasyPrint · Jinja2\nPDF export" as RG
    }
}

' ═══════════ EXTERNAL ═══════════

package "External" as EXT #FEE2E2 {
    database "**MongoDB Atlas**\nusers · sessions · history" as DB
    cloud "**Gemini 2.5 Flash**" as GAPI
}

' ═══════════ FLOWS ═══════════

Pages --> API

AuthR --> AuthS
DocR --> DocP
DocR --> PII
DocR --> SS
DocR -[#2563EB]-> HTOC : <color:#2563EB>bg
DocR -[#2563EB]-> BM25 : <color:#2563EB>bg

AnaR --> TS
AnaR --> GC
AnaR --> PII
AnaR --> RG
AnaR --> HS

ChatR --> BM25
ChatR -[#9333EA]-> TS : <color:#9333EA>fallback
ChatR --> GC
ChatR --> PII

HistR --> HS
HistR --> SS

HTOC --> GC
TS --> GC

AuthS --> DB
SS --> DB
HS --> DB
GC --> GAPI

' ═══════════ LEGEND ═══════════

legend bottom right
  **Upload:** File → OCR → PII → HTOC + BM25 (bg)
  **Chat:** Query → BM25 → Tree → Gemini → Stream
  **Zero retention:** sessions auto-expire (2h TTL)
endlegend

@enduml
