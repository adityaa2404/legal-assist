# GEMINI AI API Key (Get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Separate API key for chat (doubles your free-tier RPM)
# Get a second key from another Google AI Studio account
# GEMINI_CHAT_API_KEY=your_second_key_here

# MongoDB Connection (for local Docker)
MONGODB_URI=mongodb://mongo:27017

# Session Security
SESSION_SECRET=generate_a_long_random_string_here

# MongoDB Credentials (if using Docker auth)
MONGO_USER=admin
MONGO_PASS=password123
