# GEMINI AI API Keys (Get from Google AI Studio)
# Each key gets its own rate limit quota — 3 keys = 3x throughput
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Separate key for HTOC + tree search (heaviest consumer)
# GEMINI_HTOC_API_KEY=your_second_key_here

# Optional: Separate key for chat (keeps chat responsive)
# GEMINI_CHAT_API_KEY=your_third_key_here

# MongoDB Connection (for local Docker)
MONGODB_URI=mongodb://mongo:27017

# Session Security
SESSION_SECRET=generate_a_long_random_string_here

# MongoDB Credentials (if using Docker auth)
MONGO_USER=admin
MONGO_PASS=password123

# Optional: SMTP for email report feature
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@legal-assist.ai
